<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <!--
        Splash screen theme — compatible with ALL Android versions:
        • Android 11 and below: uses android:background + @drawable/splash (legacy path via Theme.SplashScreen parent)
        • Android 12+: uses windowSplashScreenBackground + windowSplashScreenAnimatedIcon (native SplashScreen API)
        Both paths are declared here; the OS picks the right one automatically.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Legacy (Android ≤11) fallback background -->
        <item name="android:background">@drawable/splash</item>

        <!-- Android 12+ native SplashScreen attributes -->
        <item name="windowSplashScreenBackground">#0F0C29</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="windowSplashScreenIconBackgroundColor">#0F0C29</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>